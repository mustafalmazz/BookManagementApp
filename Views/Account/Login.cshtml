@using BookManagementApp.Areas.Admin.Models
@model User
@{
    ViewData["Title"] = "Login";
    Layout = "_LogRegLayout";
}

<style>
    /* --- CSS BAŞLANGIÇ --- */
    body {
        background: linear-gradient(135deg, #f5f0e8 0%, #e8dcc8 100%);
        min-height: 100vh;
        font-family: 'Georgia', serif;
        position: relative;
        margin: 0;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: repeating-linear-gradient( 0deg, transparent, transparent 2px, rgba(139, 111, 71, 0.03) 2px, rgba(139, 111, 71, 0.03) 4px );
            pointer-events: none;
            z-index: 0;
        }

    /* MASAÜSTÜ İÇİN DAHA KOMPAKT WRAPPER */
    .login-wrapper {
        position: relative;
        width: 100%;
        max-width: 420px; /* 480px'den 420px'e düşürüldü */
        z-index: 1;
        animation: fadeInScale 0.8s ease;
        margin: auto;
    }

    .login-container {
        background: #fff9f0;
        border-radius: 20px; /* 30px'den 20px'e */
        box-shadow: 15px 15px 40px rgba(107, 85, 65, 0.2), -5px -5px 20px rgba(255, 255, 255, 0.8);
        overflow: hidden;
        border: 2px solid #e8dcc8; /* 3px'den 2px'e */
        position: relative;
    }

        .login-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 6px; /* 8px'den 6px'e */
            background: linear-gradient(90deg, #8b6f47 0%, #6b5541 50%, #a0785a 100%);
        }

    /* HEADER KISMI SIKIŞTIRILDI */
    .login-header {
        background: linear-gradient(135deg, #8b6f47 0%, #6b5541 100%);
        padding: 35px 30px; /* 50px 40px'den küçültüldü */
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .login-header::before {
            position: absolute;
            font-size: 10rem; /* 15rem'den 10rem'e */
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            opacity: 0.1;
        }

        .login-header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 30px; /* 50px'den 30px'e */
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 100"><path fill="%23fff9f0" d="M0,50 Q360,0 720,50 T1440,50 L1440,100 L0,100 Z"></path></svg>') no-repeat bottom;
            background-size: cover;
        }

    .login-icon {
        width: 70px; /* 90px'den 70px'e */
        height: 70px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 18px; /* 25px'den 18px'e */
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px; /* Alt boşluk 25'ten 15'e */
        box-shadow: 0 5px 15px rgba(0,0,0,0.15);
        border: 2px solid rgba(255, 255, 255, 0.3);
        position: relative;
        z-index: 1;
    }

        .login-icon img {
            width: 45px !important; /* 60px'den 45px'e */
        }

    .login-title {
        color: #f5f0e8;
        font-size: 2rem; /* 2.5rem'den 2rem'e */
        font-weight: 800;
        margin: 0;
        text-shadow: 1px 1px 3px rgba(0,0,0,0.3);
        letter-spacing: 1px;
        position: relative;
        z-index: 1;
    }

    .login-subtitle {
        color: rgba(245, 240, 232, 0.9);
        font-size: 0.9rem; /* 1rem'den 0.9'a */
        margin-top: 5px;
        font-style: italic;
        position: relative;
        z-index: 1;
    }

    /* FORM KISMI SIKIŞTIRILDI */
    .login-form {
        padding: 25px 35px 35px 35px; /* 40px paddingler daraltıldı */
    }

    .form-group {
        margin-bottom: 20px; /* 25'ten 20'ye */
        position: relative;
    }

    .form-label {
        display: block;
        color: #4a3f35;
        font-size: 0.9rem; /* 1rem'den 0.9'a */
        font-weight: 700;
        margin-bottom: 8px; /* 12'den 8'e */
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .form-label i {
            color: #8b6f47;
        }

    .form-input-wrapper {
        position: relative;
    }

    .form-control {
        width: 100%;
        padding: 12px 15px 12px 40px; /* Padding daraltıldı */
        border: 2px solid #e8dcc8; /* 3'ten 2'ye */
        border-radius: 12px; /* 15'ten 12'ye */
        font-size: 0.95rem; /* 1rem'den 0.95'e */
        font-family: 'Georgia', serif;
        background: #f5ede0;
        color: #4a3f35;
        transition: all 0.3s ease;
        box-shadow: inset 1px 1px 4px rgba(107, 85, 65, 0.08);
    }

        .form-control:focus {
            outline: none;
            border-color: #8b6f47;
            background: #fff;
            box-shadow: inset 1px 1px 4px rgba(107, 85, 65, 0.08), 0 0 0 3px rgba(139, 111, 71, 0.1);
            transform: translateY(-1px);
        }

    .input-icon {
        position: absolute;
        left: 15px; /* 18'den 15'e */
        top: 50%;
        transform: translateY(-50%);
        color: #8b6f47;
        font-size: 1rem; /* 1.2'den 1'e */
        pointer-events: none;
        z-index: 5;
    }

    /* ŞİFREMİ UNUTTUM */
    .forgot-password-link {
        display: block;
        text-align: right;
        margin-top: 6px;
        color: #8b6f47;
        text-decoration: none;
        font-size: 0.85rem;
        font-style: italic;
        transition: all 0.3s ease;
    }

        .forgot-password-link:hover {
            color: #6b5541;
            text-decoration: underline;
        }

    /* BUTON GRUBU */
    .button-group {
        display: flex;
        gap: 12px; /* 15'ten 12'ye */
        margin-top: 25px; /* 35'ten 25'e */
    }

    .btn {
        flex: 1;
        padding: 12px 20px; /* 16px 30px'den daraltıldı */
        border: none;
        border-radius: 12px; /* 15'ten 12'ye */
        font-size: 0.95rem; /* 1rem'den 0.95'e */
        font-weight: 700;
        font-family: 'Georgia', serif;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

        .btn span {
            position: relative;
            z-index: 1;
        }

    .btn-primary {
        background: linear-gradient(135deg, #8b6f47 0%, #6b5541 100%);
        color: #f5f0e8;
        box-shadow: 0 4px 15px rgba(107, 85, 65, 0.3);
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(107, 85, 65, 0.4);
        }

        .btn-primary:active {
            transform: translateY(-1px);
        }

    .btn-outline {
        background: transparent;
        color: #6b5541;
        border: 2px solid #8b6f47; /* 3'ten 2'ye */
        box-shadow: 0 3px 10px rgba(107, 85, 65, 0.15);
    }

        .btn-outline:hover {
            background: #8b6f47;
            color: #f5f0e8;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(107, 85, 65, 0.25);
        }

    /* GOOGLE BUTONU */
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 18px 0 12px 0; /* Boşluklar azaltıldı */
        color: #8b6f47;
        font-style: italic;
        font-size: 0.85rem;
    }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid rgba(139, 111, 71, 0.2);
        }

        .divider::before {
            margin-right: .5em;
        }

        .divider::after {
            margin-left: .5em;
        }

    .btn-google {
        width: 100%;
        background: #fff;
        color: #4a3f35;
        border: 2px solid #e8dcc8;
        box-shadow: 0 3px 10px rgba(107, 85, 65, 0.08);
        margin-top: 5px;
    }

        .btn-google:hover {
            background: #f5ede0;
            border-color: #8b6f47;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(107, 85, 65, 0.15);
        }

        .btn-google i {
            color: #DB4437;
            font-size: 1.1rem;
        }

    /* UYARI MESAJLARI DAHA KOMPAKT */
    .error-message, .success-message {
        padding: 12px 15px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .error-message {
        background: linear-gradient(135deg, rgba(220, 53, 69, 0.1) 0%, rgba(200, 35, 51, 0.05) 100%);
        border-left: 4px solid #dc3545;
        color: #721c24;
    }

    .success-message {
        background: linear-gradient(135deg, rgba(40, 167, 69, 0.1) 0%, rgba(21, 87, 36, 0.05) 100%);
        border-left: 4px solid #28a745;
        color: #155724;
        animation: fadeInScale 0.5s ease;
    }

        .error-message i, .success-message i {
            font-size: 1.1rem;
        }

    .decorative-element {
        position: absolute;
        font-size: 4rem;
        opacity: 0.05;
        pointer-events: none;
    }

        .decorative-element.top-left {
            top: 20px;
            left: 20px;
        }

    @@keyframes fadeInScale {
        from

    {
        opacity: 0;
        transform: scale(0.9);
    }

    to {
        opacity: 1;
        transform: scale(1);
    }

    }

    /* --- MOBİL UYUMLULUK --- */
    @@media (max-width: 768px) {
        .login-wrapper

    {
        max-width: 100%;
    }

    .login-header {
        padding: 25px 20px;
    }

    .login-form {
        padding: 25px 20px;
    }

    .login-title {
        font-size: 1.6rem;
    }

    .button-group {
        flex-direction: column;
        gap: 10px;
        margin-top: 20px;
    }

    .btn {
        width: 100%;
        padding: 12px;
    }

    }
</style>

<div class="login-wrapper">
    <div class="login-container">
        <div class="decorative-element top-left">📖</div>

        <div class="login-header">
            <div class="login-icon">
                <img src="/images/library.png" />
            </div>
            <h1 class="login-title">Giriş Yap</h1>
            <p class="login-subtitle">Dijital kütüphanenize hoş geldiniz</p>
        </div>

        <div class="login-form">
            <form method="post">
                @if (ViewBag.Error != null)
                {
                    <div class="error-message">
                        <i class="fas fa-exclamation-circle"></i>
                        <span>@ViewBag.Error</span>
                    </div>
                }

                @if (TempData["Success"] != null)
                {
                    <div class="success-message">
                        <i class="fas fa-check-circle"></i>
                        <span>@TempData["Success"]</span>
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">
                        Kullanıcı Adı
                    </label>
                    <div class="form-input-wrapper">
                        <i class="fas fa-user input-icon"></i>
                        <input name="username"
                               class="form-control"
                               type="text"
                               placeholder="Kullanıcı adınızı giriniz"
                               required
                               autocomplete="username" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Şifre
                    </label>
                    <div class="form-input-wrapper">
                        <i class="fas fa-lock input-icon"></i>
                        <input name="password"
                               class="form-control"
                               type="password"
                               placeholder="Şifrenizi giriniz"
                               required
                               autocomplete="current-password" />
                    </div>
                    <a asp-action="ForgotPassword" class="forgot-password-link">
                        <i class="fas fa-key" style="font-size: 0.8rem;"></i> Şifremi Unuttum
                    </a>
                </div>

                <div class="button-group">
                    <button type="submit" class="btn btn-primary">
                        <span>
                            <i class="fas fa-sign-in-alt"></i> Giriş Yap
                        </span>
                    </button>
                    <a class="btn btn-outline" asp-action="Register">
                        <span>
                            <i class="fas fa-user-plus"></i> Kayıt Ol
                        </span>
                    </a>
                </div>

                <div class="divider">veya</div>

                <a asp-action="GoogleLogin" asp-controller="Account" class="btn btn-google">
                    <span>
                        <i class="fab fa-google"></i> Google ile Giriş Yap
                    </span>
                </a>

            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const inputs = document.querySelectorAll('.form-control');
        inputs.forEach(input => {
            input.addEventListener('focus', function() {
                this.parentElement.querySelector('.input-icon').style.transform = 'translateY(-50%) scale(1.1)';
                this.parentElement.querySelector('.input-icon').style.color = '#8b6f47';
            });
            input.addEventListener('blur', function() {
                this.parentElement.querySelector('.input-icon').style.transform = 'translateY(-50%) scale(1)';
                this.parentElement.querySelector('.input-icon').style.color = '#8b6f47';
            });
        });

        const alertMessage = document.querySelector('.error-message, .success-message');
        if (alertMessage) {
            alertMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });
</script>