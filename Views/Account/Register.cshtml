@using BookManagementApp.Areas.Admin.Models
@model User
@{
    ViewData["Title"] = "Register";
    Layout = "_LogRegLayout";
}

<style>
    /* --- VALIDATION CSS --- */
    .text-danger {
        color: #dc3545;
        font-size: 0.8rem;
        margin-top: 3px;
        font-weight: 600;
        display: block;
        padding-left: 10px;
        animation: fadeIn 0.3s ease;
    }

    .field-validation-error {
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .field-validation-error::before {
            font-family: 'Font Awesome 5 Free';
            font-weight: 900;
            content: "\f06a";
        }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(-5px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* --- GENEL AYARLAR --- */
    body {
        background: linear-gradient(135deg, #f5f0e8 0%, #e8dcc8 100%);
        min-height: 100vh;
        font-family: 'Georgia', serif;
        position: relative;
        margin: 0;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: repeating-linear-gradient( 0deg, transparent, transparent 2px, rgba(139, 111, 71, 0.03) 2px, rgba(139, 111, 71, 0.03) 4px );
            pointer-events: none;
            z-index: 0;
        }

    /* --- MASAÜSTÜ İÇİN DAHA KOMPAKT WRAPPER --- */
    .register-wrapper {
        position: relative;
        width: 100%;
        max-width: 420px; /* 500px'den 420px'e düşürüldü */
        z-index: 1;
        margin: auto;
        animation: fadeInScale 0.8s ease;
    }

    .register-container {
        background: #fff9f0;
        border-radius: 20px; /* 30px'den 20px'e düşürüldü */
        box-shadow: 15px 15px 40px rgba(107, 85, 65, 0.2), -5px -5px 20px rgba(255, 255, 255, 0.8);
        overflow: hidden;
        border: 2px solid #e8dcc8; /* 3px'den 2px'e */
        position: relative;
    }

        .register-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 6px; /* 8px'den 6px'e */
            background: linear-gradient(90deg, #8b6f47 0%, #6b5541 50%, #a0785a 100%);
        }

    /* --- HEADER SIKIŞTIRILDI --- */
    .register-header {
        background: linear-gradient(135deg, #8b6f47 0%, #6b5541 100%);
        padding: 30px 30px; /* 40px 40px'den küçültüldü */
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .register-header::before {
            position: absolute;
            font-size: 10rem; /* 15rem'den 10rem'e */
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            opacity: 0.1;
        }

        .register-header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 30px; /* 50px'den 30px'e */
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 100"><path fill="%23fff9f0" d="M0,50 Q360,0 720,50 T1440,50 L1440,100 L0,100 Z"></path></svg>') no-repeat bottom;
            background-size: cover;
        }

    .register-icon {
        width: 70px; /* 100px'den 70px'e */
        height: 70px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 18px; /* 25px'den 18px'e */
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px; /* Alt boşluk azaltıldı */
        font-size: 2rem; /* 3rem'den 2rem'e */
        color: #f5f0e8;
        box-shadow: 0 5px 15px rgba(0,0,0,0.15);
        border: 2px solid rgba(255, 255, 255, 0.3);
        position: relative;
        z-index: 1;
    }

    .register-title {
        color: #f5f0e8;
        font-size: 2rem; /* 2.5rem'den 2rem'e */
        font-weight: 800;
        margin: 0;
        text-shadow: 1px 1px 3px rgba(0,0,0,0.3);
        letter-spacing: 1px;
        position: relative;
        z-index: 1;
    }

    .register-subtitle {
        color: rgba(245, 240, 232, 0.9);
        font-size: 0.9rem; /* 1rem'den 0.9'a */
        margin-top: 5px;
        font-style: italic;
        position: relative;
        z-index: 1;
    }

    /* --- FORM SIKIŞTIRILDI --- */
    .register-form {
        padding: 25px 35px 30px 35px; /* Paddingler daraltıldı */
    }

    .form-group {
        margin-bottom: 15px; /* 25'ten 15'e */
        position: relative;
    }

    .form-label {
        display: block;
        color: #4a3f35;
        font-size: 0.9rem; /* 1rem'den 0.9'a */
        font-weight: 700;
        margin-bottom: 6px; /* 12'den 6'ya */
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .form-label i {
            color: #8b6f47;
        }

    .form-input-wrapper {
        position: relative;
    }

    .form-control {
        width: 100%;
        padding: 12px 15px 12px 40px; /* Padding daraltıldı */
        border: 2px solid #e8dcc8; /* 3'ten 2'ye */
        border-radius: 12px; /* 15'ten 12'ye */
        font-size: 0.95rem; /* 1rem'den 0.95'e */
        font-family: 'Georgia', serif;
        background: #f5ede0;
        color: #4a3f35;
        transition: all 0.3s ease;
        box-shadow: inset 1px 1px 4px rgba(107, 85, 65, 0.08);
    }

        .form-control:focus {
            outline: none;
            border-color: #8b6f47;
            background: #fff;
            box-shadow: inset 1px 1px 4px rgba(107, 85, 65, 0.08), 0 0 0 3px rgba(139, 111, 71, 0.1);
            transform: translateY(-1px);
        }

    .input-icon {
        position: absolute;
        left: 15px; /* 18'den 15'e */
        top: 50%;
        transform: translateY(-50%);
        color: #8b6f47;
        font-size: 1rem; /* 1.2'den 1'e */
        pointer-events: none;
        z-index: 5;
    }

    /* --- BUTONLAR SIKIŞTIRILDI --- */
    .btn {
        width: 100%;
        padding: 12px 20px; /* 18px 30px'den daraltıldı */
        border: none;
        border-radius: 12px; /* 15'ten 12'ye */
        font-size: 0.95rem; /* 1.1'den 0.95'e */
        font-weight: 700;
        font-family: 'Georgia', serif;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        margin-top: 10px; /* 15'ten 10'a */
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .btn span {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

    .btn-primary {
        background: linear-gradient(135deg, #8b6f47 0%, #6b5541 100%);
        color: #f5f0e8;
        box-shadow: 0 4px 15px rgba(107, 85, 65, 0.3);
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(107, 85, 65, 0.4);
        }

    /* Divider & Google */
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 15px 0 10px 0; /* Boşluklar azaltıldı */
        color: #8b6f47;
        font-style: italic;
        font-size: 0.85rem;
    }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid rgba(139, 111, 71, 0.2);
        }

        .divider::before {
            margin-right: .5em;
        }

        .divider::after {
            margin-left: .5em;
        }

    .btn-google {
        background: #fff;
        color: #4a3f35;
        border: 2px solid #e8dcc8;
        text-decoration: none;
        padding: 12px 20px; /* Buton içi daraltıldı */
        box-shadow: 0 3px 10px rgba(107, 85, 65, 0.08);
    }

        .btn-google:hover {
            background: #f5ede0;
            border-color: #8b6f47;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(107, 85, 65, 0.15);
        }

        .btn-google i {
            color: #DB4437;
        }

    .decorative-element {
        position: absolute;
        font-size: 4rem;
        opacity: 0.05;
        pointer-events: none;
    }

        .decorative-element.top-left {
            top: 20px;
            left: 20px;
        }

    @@keyframes fadeInScale {
        from

    {
        opacity: 0;
        transform: scale(0.9);
    }

    to {
        opacity: 1;
        transform: scale(1);
    }

    }

    /* --- MOBİL GÖRÜNÜM (AYNEN KORUNDU) --- */
    @@media (max-width: 768px) {
        body

    {
        padding: 10px;
    }

    .register-wrapper {
        max-width: 100%;
    }

    .register-header {
        padding: 25px 20px;
    }

    .register-form {
        padding: 25px 20px;
    }

    .register-title {
        font-size: 1.6rem;
    }

    .register-subtitle {
        font-size: 0.9rem;
    }

    .register-icon {
        margin-bottom: 15px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-label {
        font-size: 0.9rem;
        margin-bottom: 6px;
    }

    .form-control {
        padding: 12px 15px 12px 45px;
        font-size: 0.95rem;
    }

    .input-icon {
        font-size: 1rem;
    }

    .btn {
        padding: 12px;
        font-size: 1rem;
        margin-top: 10px;
    }

    .btn-google {
        padding: 12px;
        font-size: 0.95rem;
    }

    .divider {
        margin: 15px 0;
    }

    }
</style>

<div class="register-wrapper">
    <div class="register-container">
        <div class="decorative-element top-left">📖</div>

        <div class="register-header">
            <div class="register-icon">
                <i class="fas fa-user-plus"></i>
            </div>
            <h1 class="register-title">Kayıt Ol</h1>
            <p class="register-subtitle">Yeni bir okur hesabı oluşturun</p>
        </div>

        <div class="register-form">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 10px; text-align: center;"></div>

                <div class="form-group">
                    <label asp-for="UserName" class="form-label">
                        Kullanıcı Adı
                    </label>
                    <div class="form-input-wrapper">
                        <i class="fas fa-user input-icon"></i>
                        <input asp-for="UserName"
                               class="form-control"
                               type="text"
                               placeholder="Kullanıcı adınızı seçiniz"
                               autocomplete="username" />
                    </div>
                    <span asp-validation-for="UserName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">
                        Email
                    </label>
                    <div class="form-input-wrapper">
                        <i class="fas fa-envelope input-icon"></i>
                        <input asp-for="Email"
                               class="form-control"
                               type="email"
                               placeholder="email@example.com"
                               autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PasswordHash" class="form-label">
                        Şifre
                    </label>
                    <div class="form-input-wrapper">
                        <i class="fas fa-lock input-icon"></i>
                        <input asp-for="PasswordHash"
                               class="form-control"
                               type="password"
                               placeholder="Güçlü bir şifre oluşturun"
                               autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="PasswordHash" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="form-label">
                        Şifre Tekrar
                    </label>
                    <div class="form-input-wrapper">
                        <i class="fas fa-lock input-icon"></i>
                        <input asp-for="ConfirmPassword"
                               class="form-control"
                               type="password"
                               placeholder="Şifrenizi tekrar girin"
                               autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">
                    <span>
                        <i class="fas fa-user-check"></i>
                        Hesap Oluştur
                    </span>
                </button>
                <div class="divider">veya</div>

                <a asp-action="GoogleLogin" asp-controller="Account" class="btn btn-google">
                    <span>
                        <i class="fab fa-google"></i>
                        Google ile Kaydol
                    </span>
                </a>
                <div style="text-align: center; margin-top: 15px;">
                    <p style="color: #6b5541; font-size: 0.9rem; margin-bottom: 0;">
                        Zaten bir hesabınız var mı?
                        <a asp-action="Login" style="color: #8b6f47; font-weight: bold; text-decoration: none;">Giriş Yap</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Form input animasyonları
    document.addEventListener('DOMContentLoaded', function() {
        const inputs = document.querySelectorAll('.form-control');

        inputs.forEach(input => {
            input.addEventListener('focus', function() {
                this.parentElement.querySelector('.input-icon').style.transform = 'translateY(-50%) scale(1.1)';
                this.parentElement.querySelector('.input-icon').style.color = '#8b6f47';
            });

            input.addEventListener('blur', function() {
                this.parentElement.querySelector('.input-icon').style.transform = 'translateY(-50%) scale(1)';
                this.parentElement.querySelector('.input-icon').style.color = '#8b6f47';
            });
        });
    });
</script>