        opacity: 0.8;
        animation: sunPulse 5s infinite alternate;
    }

    @@keyframes sunPulse {
        from

    {
        transform: scale(1);
        opacity: 0.8;
    }

    to {
        transform: scale(1.2);
        opacity: 1;
    }

    }

    /* Ağaç Sahnesi */
    .tree-stage {
