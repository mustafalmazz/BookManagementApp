    .stage-sprout {
        color: #8bc34a;
    }
    /* Filiz - Açık Yeşil */
    .stage-sapling {
        color: #4caf50;
    }
    /* Fidan - Yeşil */
    .stage-tree {
        color: #2e7d32;
    }
    /* Ağaç - Koyu Yeşil */
    .stage-master { /* Tamamlanmış - Altın/Meyveli */
