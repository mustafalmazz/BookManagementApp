        display: flex;
        align-items: flex-end;
        justify-content: center;
        margin: 20px 0;
        position: relative;
    }

    .tree-icon {
        font-size: 0rem; /* Başlangıçta görünmez */
        transition: all 1.5s cubic-bezier(0.34, 1.56, 0.64, 1); /* Zıplama efekti */
        filter: drop-shadow(0 10px 5px rgba(0,0,0,0.1));
    }

    /* Büyüme Aşamaları Renkleri */
    .stage-seed {
        color: #8d6e63;
    }
