@using BookManagementApp.Areas.Admin.Models
@model UserProfileViewModel
@{
    ViewData["Title"] = "Profil Özetim";

    // --- YILLIK ---
    int yearlyRead = Model.BooksReadThisYear;      // DB'den gelen otomatik sayı
    int yearlyGoal = Model.YearlyReadingGoal;      // Senin belirlediğin hedef

    int yearlyProgress = yearlyGoal > 0
        ? Math.Min(100, (int)((double)yearlyRead / yearlyGoal * 100))
        : 0;

    // --- AYLIK (DÜZELTİLDİ) ---
    int monthlyRead = Model.MonthlyPagesRead; 
    int monthlyGoal = Model.MonthlyReadingGoal;    // Senin modal'dan girdiğin manuel hedef

    int monthlyProgress = monthlyGoal > 0
         ? Math.Min(100, (int)((double)monthlyRead / monthlyGoal * 100))
         : 0;
}

<style>
    /* --- MEVCUT STİLLER (KORUNDU) --- */
    body {
        background: linear-gradient(135deg, #f5f0e8 0%, #e8dcc8 100%);
        font-family: 'Georgia', serif;
