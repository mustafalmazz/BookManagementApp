<div class="modal fade" id="monthlyGoalModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content custom-modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fs-6">Aylık İlerlemeyi Düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="small text-muted mb-1">Okunan Sayfa:</label>
                <input type="number" id="manualReadInput" class="form-control text-center mb-3" value="@monthlyRead" placeholder="0">

                <label class="small text-muted mb-1">Aylık Hedef:</label>
                <input type="number" id="manualGoalInput" class="form-control text-center" value="@monthlyGoal" placeholder="1000">
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-sm btn-save-custom w-100" id="saveMonthlyGoalBtn">Kaydet</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="goalModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content custom-modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fs-6">Yıllık Hedefi Düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="number" id="newGoalInput" class="form-control text-center" value="@Model.YearlyReadingGoal" min="1" max="1000">
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-sm btn-save-custom w-100" id="saveGoalBtn">Güncelle</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Sayfa yüklendiğinde varsayılan olan Yıllık barını doldur
        setTimeout(function() {
            const bar = document.getElementById('yearlyProgressBar');
            if(bar) bar.style.width = bar.getAttribute('data-width');
        }, 300);
    });

    // --- TAB GEÇİŞ İŞLEMİ ---
    function switchGoal(type) {
        const yearlySec = document.getElementById('yearlyGoalSection');
        const monthlySec = document.getElementById('monthlyGoalSection');
        const btnYearly = document.getElementById('btnShowYearly');
        const btnMonthly = document.getElementById('btnShowMonthly');

        if (type === 'yearly') {
            yearlySec.style.display = 'block';
            monthlySec.style.display = 'none';
            btnYearly.classList.add('active');
            btnMonthly.classList.remove('active');

            setTimeout(() => {
                const bar = document.getElementById('yearlyProgressBar');
                if(bar) bar.style.width = bar.getAttribute('data-width');
            }, 100);

        } else {
            yearlySec.style.display = 'none';
            monthlySec.style.display = 'block';
            btnYearly.classList.remove('active');
            btnMonthly.classList.add('active');

            setTimeout(() => {
                const bar = document.getElementById('monthlyProgressBar');
                if(bar) bar.style.width = bar.getAttribute('data-width');
            }, 100);
        }
    }

    // --- AVATAR İŞLEMLERİ ---
    let selectedAvatarUrl = "";
    let uploadedFile = null;

    function selectAvatar(imgElement) {
        document.querySelectorAll('.avatar-option').forEach(img => img.classList.remove('selected'));
        imgElement.classList.add('selected');
        selectedAvatarUrl = imgElement.src;
        uploadedFile = null;
    }

    const fileInput = document.getElementById('customAvatarFile');
    if(fileInput){
        fileInput.addEventListener('change', function(event) {
            const file = event.target.files[0];
            if (file) {
                uploadedFile = file;
                selectedAvatarUrl = "";
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('uploadPreview').innerHTML = `<img src="${e.target.result}" style="width:100%; height:100%; object-fit:cover;">`;
                }
                reader.readAsDataURL(file);
            }
        });
    }

    const saveAvatarBtn = document.getElementById('saveAvatarBtn');
    if(saveAvatarBtn){
        saveAvatarBtn.addEventListener('click', function() {
            const formData = new FormData();
            if (uploadedFile) {
                formData.append('file', uploadedFile);
            } else if (selectedAvatarUrl) {
                formData.append('avatarUrl', selectedAvatarUrl);
            } else {
                alert("Lütfen bir avatar seçin veya fotoğraf yükleyin.");
                return;
            }

            const btn = this;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor...';
            btn.disabled = true;

            fetch('/Profile/UpdateAvatar', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert("Hata: " + data.message);
                    btn.innerHTML = 'Kaydet';
                    btn.disabled = false;
                }
            })
            .catch(error => {
                console.error('Hata:', error);
                alert("Bir hata oluştu.");
                btn.innerHTML = 'Kaydet';
                btn.disabled = false;
            });
        });
    }

    // --- YILLIK HEDEF GÜNCELLEME (DÜZELTİLDİ) ---
    const saveGoalBtn = document.getElementById('saveGoalBtn');
    if(saveGoalBtn){
        saveGoalBtn.addEventListener('click', function() {
            const newGoal = document.getElementById('newGoalInput').value;
            // DÜZELTME: Artık özel URL'e gidiyor (/Profile/UpdateYearlyGoal)
            updateReadingGoal(newGoal, this, '/Profile/UpdateYearlyGoal');
        });
    }

    // --- AYLIK HEDEF GÜNCELLEME (DÜZELTİLDİ) ---
    const saveMonthlyBtn = document.getElementById('saveMonthlyGoalBtn');
     if(saveMonthlyBtn){
         saveMonthlyBtn.addEventListener('click', function() {
             // İki değeri de alıyoruz
             const readVal = document.getElementById('manualReadInput').value;
             const goalVal = document.getElementById('manualGoalInput').value;

             if(goalVal < 1 || readVal < 0) {
                 alert("Lütfen geçerli değerler giriniz.");
                 return;
             }

             const btnElement = this;
             const oldText = btnElement.innerHTML;
             btnElement.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> ...';
             btnElement.disabled = true;

             const formData = new URLSearchParams();
             formData.append('goal', goalVal);
             formData.append('readPages', readVal); // Controller'daki parametre isimleri

             fetch('/Profile/UpdateMonthlyGoal', {
                 method: 'POST',
                 headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                 body: formData
             })
             .then(response => response.json())
             .then(data => {
                 if (data.success) {
                     location.reload();
                 } else {
                     alert("Hata: " + data.message);
                     btnElement.innerHTML = oldText;
                     btnElement.disabled = false;
                 }
             })
             .catch(error => {
                 console.error('Hata:', error);
                 btnElement.innerHTML = oldText;
                 btnElement.disabled = false;
             });
         });
     }
    // --- ORTAK HEDEF GÜNCELLEME FONKSİYONU ---
    // endpointUrl parametresi eklendi
    function updateReadingGoal(goalValue, btnElement, endpointUrl) {
        if(goalValue < 1) {
            alert("Lütfen geçerli bir hedef giriniz.");
            return;
        }

        const oldText = btnElement.innerHTML;
        btnElement.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> ...';
        btnElement.disabled = true;

        const formData = new URLSearchParams();
        formData.append('goal', goalValue);

        // Dinamik URL kullanımı
        fetch(endpointUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert("Hata: " + data.message);
                btnElement.innerHTML = oldText;
                btnElement.disabled = false;
            }
        })
        .catch(error => {
            console.error('Hata:', error);
            alert("Bir bağlantı hatası oluştu.");
            btnElement.innerHTML = oldText;
            btnElement.disabled = false;
        });
    }
</script>