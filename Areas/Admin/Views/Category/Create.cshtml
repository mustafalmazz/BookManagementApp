@model Category

@{
    ViewData["Title"] = "Yeni Kategori Ekle";
}

<style>
    /* --- GENEL TEMA VE ARKA PLAN --- */
    body {
        background: linear-gradient(135deg, #f5f0e8 0%, #e8dcc8 100%);
        font-family: 'Georgia', serif;
        color: #4a3f35;
    }

    h1 {
        color: #4a3f35;
        font-weight: 800;
        margin-top: 40px;
    }

    hr {
        border-color: #8b6f47;
        opacity: 0.2;
        max-width: 600px;
        margin: 15px auto 40px auto;
    }

    /* --- FORM KARTI STİLLERİ --- */
    .category-form {
        background: #fff9f0;
        border-radius: 20px;
        padding: 40px;
        max-width: 500px; /* Tek input olduğu için daha dar ve şık bir kart */
        margin: 0 auto;
        box-shadow: 0 10px 30px rgba(107, 85, 65, 0.15);
        border: 2px solid rgba(139, 111, 71, 0.05);
    }

    .form-label {
        color: #8b6f47;
        font-weight: 600;
        margin-bottom: 10px;
        font-size: 1.05rem;
    }

    .form-control {
        background-color: #fff;
        color: #4a3f35;
        border: 2px solid #e8dcc8;
        border-radius: 12px;
        padding: 15px;
        transition: all 0.3s ease;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        font-size: 1rem;
    }

        .form-control:focus {
            background-color: #fff;
            color: #4a3f35;
            border-color: #8b6f47;
            box-shadow: 0 0 10px rgba(139, 111, 71, 0.15);
            outline: 0;
        }

    /* --- BUTON STİLLERİ --- */
    .btn-submit {
        background: linear-gradient(135deg, #8b6f47, #6b5541);
        border: none;
        color: #fff;
        transition: all 0.3s ease;
        font-weight: 700;
        width: 100%;
        padding: 14px;
        font-size: 1.1rem;
        border-radius: 12px;
        font-family: 'Georgia', serif;
    }

        .btn-submit:hover {
            background: linear-gradient(135deg, #a0785a, #8b6f47);
            box-shadow: 0 8px 20px rgba(107, 85, 65, 0.2);
            color: #fff;
            transform: translateY(-3px);
        }

    /* Geri Dön Linki */
    .back-link {
        color: #8b6f47;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 600;
        transition: color 0.2s ease;
        display: inline-block;
        margin-top: 15px;
    }

        .back-link:hover {
            color: #4a3f35;
            text-decoration: underline;
        }
</style>

<div class="container">
    <h1 class="text-center">
        <i class="fa-solid fa-layer-group" style="color: #a0785a;"></i> Yeni Kategori Ekle
    </h1>
    <hr />

    <form action="Create" method="post" class="category-form">
        <div class="mb-4">
            <label class="form-label" asp-for="CategoryName">Kategori Adı</label>
            <input class="form-control" asp-for="CategoryName" placeholder="Örn: Kişisel Gelişim" autocomplete="off" />
            <span asp-validation-for="CategoryName" class="text-danger mt-1 d-block" style="font-size:0.85rem;"></span>
        </div>

        <button type="submit" class="btn btn-submit">
            <i class="fa-solid fa-plus"></i> Kategori Ekle
        </button>

        <div class="text-center mt-3">
            <a href="/Admin/Category/Index" class="back-link">
                <i class="fa-solid fa-arrow-left"></i> Listeye Dön
            </a>
        </div>
    </form>
</div>